generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  password   String
  role       UserRole
  createdAt  DateTime   @default(now())
  businesses Business[]
  partTimer  PartTimer?
}

enum UserRole {
  owner
  part_timer
}

model Business {
  id              String             @id @default(cuid())
  name            String
  owner           User               @relation(fields: [ownerUserId], references: [id])
  ownerUserId     String
  ownerName       String?
  ownerPhone      String?
  avatarEmoji     String?
  avatarColor     String?
  logoUrl         String?
  businessAddress String?
  createdAt       DateTime           @default(now())
  rosterMembers   RosterMembership[]
  shifts          Shift[]
  partTimerSkills PartTimerSkill[]
}

model PartTimer {
  id           String             @id @default(cuid())
  user         User               @relation(fields: [userId], references: [id])
  userId       String             @unique
  name         String
  phone        String?
  email        String
  profilePhoto String?
  avatarEmoji  String?
  avatarColor  String?
  createdAt    DateTime           @default(now())
  skills       PartTimerSkill[]
  availability Availability[]
  memberships  RosterMembership[]
  assignments  ShiftAssignment[]
  interests    ShiftInterest[]
}

model RosterMembership {
  id          String           @id @default(cuid())
  business    Business         @relation(fields: [businessId], references: [id])
  businessId  String
  partTimer   PartTimer        @relation(fields: [partTimerId], references: [id])
  partTimerId String
  invitedAt   DateTime         @default(now())
  status      MembershipStatus @default(invited)
  inviteToken String?          @unique

  @@unique([businessId, partTimerId])
}

enum MembershipStatus {
  invited
  active
  removed
}

model Skill {
  id             String           @id @default(cuid())
  label          String           @unique
  defaultPayType PayType?
  defaultPayRate Decimal?         @db.Decimal(10, 2)
  archived       Boolean          @default(false)
  partTimers     PartTimerSkill[]
  shiftRoles     ShiftRole[]
}

model PartTimerSkill {
  partTimer   PartTimer @relation(fields: [partTimerId], references: [id])
  partTimerId String
  skill       Skill     @relation(fields: [skillId], references: [id])
  skillId     String
  business    Business  @relation(fields: [businessId], references: [id])
  businessId  String

  @@id([partTimerId, skillId, businessId])
}

model Availability {
  id          String                 @id @default(cuid())
  partTimer   PartTimer              @relation(fields: [partTimerId], references: [id])
  partTimerId String
  dayOfWeek   DayOfWeek
  preference  AvailabilityPreference @default(flexible)
}

enum AvailabilityPreference {
  morning
  afternoon
  flexible
}

enum DayOfWeek {
  Mon
  Tue
  Wed
  Thu
  Fri
  Sat
  Sun
}

model Shift {
  id          String            @id @default(cuid())
  business    Business          @relation(fields: [businessId], references: [id])
  businessId  String
  title       String
  shiftDate   DateTime
  startTime   String
  endTime     String
  status      ShiftStatus       @default(draft)
  archived    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  assignments ShiftAssignment[]
  roles       ShiftRole[]
  interests   ShiftInterest[]
}

model ShiftRole {
  id          String            @id @default(cuid())
  shift       Shift             @relation(fields: [shiftId], references: [id])
  shiftId     String
  skill       Skill             @relation(fields: [skillId], references: [id])
  skillId     String
  count       Int               @default(1)
  payType     PayType
  payRate     Decimal           @db.Decimal(10, 2)
  assignments ShiftAssignment[]
  interests   ShiftInterest[]
}

enum PayType {
  hourly
  flat_session
}

enum ShiftStatus {
  draft
  open
  filled
  completed
  cancelled
}

model ShiftAssignment {
  id            String           @id @default(cuid())
  shift         Shift            @relation(fields: [shiftId], references: [id])
  shiftId       String
  partTimer     PartTimer        @relation(fields: [partTimerId], references: [id])
  partTimerId   String
  shiftRole     ShiftRole?       @relation(fields: [shiftRoleId], references: [id])
  shiftRoleId   String?
  status        AssignmentStatus @default(assigned)
  hoursLogged   Decimal?         @db.Decimal(5, 2)
  payAmount     Decimal?         @db.Decimal(10, 2)
  paymentStatus PaymentStatus    @default(unpaid)
  paidAt        DateTime?
  createdAt     DateTime         @default(now())
}

enum AssignmentStatus {
  assigned
  completed
  cancelled
}

enum PaymentStatus {
  unpaid
  paid
}

model ShiftInterest {
  id          String         @id @default(cuid())
  shift       Shift          @relation(fields: [shiftId], references: [id])
  shiftId     String
  shiftRole   ShiftRole?     @relation(fields: [shiftRoleId], references: [id])
  shiftRoleId String?
  partTimer   PartTimer      @relation(fields: [partTimerId], references: [id])
  partTimerId String
  status      InterestStatus @default(pending)
  comment     String?
  createdAt   DateTime       @default(now())

  @@unique([shiftId, partTimerId, shiftRoleId])
}

enum InterestStatus {
  pending
  confirmed
  rejected
  withdrawn
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  recipientId String
  entityType  String
  entityId    String
  metadata    Json?
  read        Boolean      @default(false)
  createdAt   DateTime     @default(now())
}

enum ActivityType {
  INTEREST_CONFIRMED
  INTEREST_REJECTED
  ASSIGNED
  SHIFT_CANCELLED
  PAID
  INTEREST_RECEIVED
  INTEREST_WITHDRAWN
  HOURS_LOGGED
  KUDOS_RECEIVED
}

model ObjectiveRecord {
  id          String               @id @default(cuid())
  shiftId     String
  partTimerId String
  businessId  String
  attendance  Attendance
  qualityFlag QualityFlag?
  comment     String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tags        ObjectiveRecordTag[]

  @@unique([shiftId, partTimerId])
}

model PerformanceTag {
  id         String               @id @default(cuid())
  businessId String
  label      String
  archived   Boolean              @default(false)
  records    ObjectiveRecordTag[]

  @@unique([businessId, label])
}

model ObjectiveRecordTag {
  recordId String
  tagId    String
  record   ObjectiveRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  tag      PerformanceTag  @relation(fields: [tagId], references: [id])

  @@id([recordId, tagId])
}

model Kudos {
  id          String   @id @default(cuid())
  partTimerId String
  businessId  String
  shiftId     String
  message     String
  createdAt   DateTime @default(now())

  @@unique([shiftId, partTimerId])
}

enum Attendance {
  attended
  late
  no_show
}

enum QualityFlag {
  good
  issues
}
